# Скопируйте в .env (рядом с docker-compose.yml) на VPS и заполните.
# Это переменные для docker-compose — не путать с backend/.env.example
# (тот нужен только при запуске backend нативно, без Docker).

# Секрет для подписи JWT. Сгенерировать:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me

# Код первого запуска — вводится в визарде /setup, создающем первого админа.
# Сгенерировать: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
SETUP_TOKEN=change-me

# Пароль PostgreSQL внутри docker-сети (необязательно менять для одиночного VPS)
#POSTGRES_PASSWORD=barbershop

# ── Домен и HTTPS (Caddy) ────────────────────────────────────────
# Не задано / ":80" — обычный HTTP по IP (годится до покупки домена).
# Как только домен указывает на VPS (A-запись), впишите его сюда и
# перезапустите caddy (docker compose up -d caddy) — сертификат Let's
# Encrypt Caddy получает сам, без дополнительной настройки.
#SITE_ADDRESS=your-domain.ru

# Секьюрный флаг cookie с access-токеном — включайте true, ТОЛЬКО когда
# SITE_ADDRESS — настоящий домен с HTTPS через Caddy. На голом HTTP true
# сломает вход (браузер отбросит cookie).
#COOKIE_SECURE=false

# Базовый URL фронтенда — используется в ссылке сброса пароля в письме.
# По умолчанию http://localhost — обновите на реальный адрес/домен.
#FRONTEND_BASE_URL=http://localhost

# ── Email (SMTP) ─────────────────────────────────────────────────
# Без настройки — попытки отправки просто падают в лог (см.
# backend/app/utils/email.py), приложение при этом не ломается. Пример для
# Yandex: smtp.yandex.ru:465, SMTP_USE_TLS=true, пароль — "пароль приложения"
# (id.yandex.ru/security), не обычный пароль от почты.
#SMTP_HOST=smtp.yandex.ru
#SMTP_PORT=465
#SMTP_USER=your-account@yandex.ru
#SMTP_PASSWORD=
#SMTP_USE_TLS=true
#SMTP_FROM_EMAIL=your-account@yandex.ru
#SMTP_FROM_NAME=Барбершоп «Сайтама»

# ── VK ID (OAuth) ────────────────────────────────────────────────
# Требует HTTPS (настоящий домен через Caddy) — VK ID не работает по IP/http
# в проде. Получить client_id: id.vk.com/business, redirect URI приложения —
# https://<ваш домен>/api/auth/vk/callback (должен совпадать с VK_REDIRECT_URI).
#VK_CLIENT_ID=
#VK_CLIENT_SECRET=
#VK_REDIRECT_URI=https://your-domain.ru/api/auth/vk/callback

# ── Бэкапы БД — S3 (необязательно) ────────────────────────────────
# Ежедневный бэкап на диск VPS (./backups) включён всегда без настройки —
# см. docker-compose.yml (backup-local). Эти переменные нужны только для
# ВТОРОГО, дополнительного бэкапа во внешнее S3-совместимое хранилище
# (переживает потерю самого VPS, в отличие от локального) — заполните и
# запустите `docker compose --profile s3-backup up -d`, иначе backup-s3
# просто не стартует. Подходит любое S3-совместимое хранилище (Yandex
# Object Storage, Selectel, Backblaze B2, AWS S3 и т.п.) — для AWS S3
# S3_BACKUP_ENDPOINT можно оставить пустым.
#S3_BACKUP_ENDPOINT=https://storage.yandexcloud.net
#S3_BACKUP_REGION=ru-central1
#S3_BACKUP_BUCKET=your-bucket-name
#S3_BACKUP_ACCESS_KEY_ID=
#S3_BACKUP_SECRET_ACCESS_KEY=

# ── Мониторинг ошибок (Sentry) ─────────────────────────────────────
# TODO: аккаунт на sentry.io ещё не создан (регистрация была недоступна —
# 403). Как только появится доступ: завести проект (Platform: FastAPI для
# бэкенда — DSN один и тот же для обоих SDK, если проект общий, либо
# отдельные проекты Python/Vue), вписать оба значения ниже.
#
# SENTRY_DSN — обычная переменная окружения контейнера backend, меняется
# в любой момент (`docker compose up -d backend`, без пересборки).
#
# VITE_SENTRY_DSN — ЗАПЕКАЕТСЯ В БАНДЛ на этапе сборки фронтенда (Vite
# build ARG, см. frontend/Dockerfile), это НЕ обычная переменная
# окружения контейнера. Пусто -> Sentry.init(...) не вызывается и весь
# @sentry/vue выпиливается tree-shaking'ом из бандла. Смена значения
# требует пересборки: `docker compose up --build -d frontend`.
#SENTRY_DSN=https://xxxxxxxx@oXXXXXX.ingest.de.sentry.io/XXXXXXX
#VITE_SENTRY_DSN=https://xxxxxxxx@oXXXXXX.ingest.de.sentry.io/XXXXXXX
