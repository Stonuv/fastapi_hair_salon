# Скопируйте в backend/.env и заполните под своё окружение.
# Полный список настроек и их дефолты — backend/app/config.py.

# PostgreSQL 13+ (нужны права на CREATE EXTENSION btree_gist)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/barbershop

# Секрет для подписи JWT. При DEBUG=false приложение не стартует
# с дефолтным значением. Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production

# Код первого запуска: POST /api/setup (создание первого админа) публичен по
# необходимости — без этого кода любой, кто откроет /setup раньше вас после
# деплоя, станет админом. При DEBUG=false обязателен, иначе приложение не
# стартует. Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(24))"
SETUP_TOKEN=change-me-in-production

# true — dev-режим (reload, дефолтный секрет допустим); false — прод
DEBUG=true

# Где слушать (0.0.0.0 — наружу, например в контейнере)
HOST=127.0.0.1
PORT=8000

# Время жизни access-токена в минутах (по умолчанию 1440 = 24 часа)
#ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Флаг Secure на cookie с access-токеном. НЕ совпадает с DEBUG=false:
# docker-compose поднимает только plain HTTP, включайте true только когда
# перед приложением реально стоит TLS-терминатор — иначе браузер отбросит
# cookie и вход перестанет работать.
#COOKIE_SECURE=false

# Защита от перебора: блокировка входа после N неудач за M минут
#LOGIN_MAX_FAILED_ATTEMPTS=5
#LOGIN_LOCKOUT_MINUTES=15
#PASSWORD_RESET_MAX_REQUESTS_PER_HOUR=3

# Время жизни токена сброса пароля в минутах
#PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# Разрешённые CORS-источники (JSON-список)
#CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Email (SMTP) — дефолты нацелены на локальный Mailpit:
#   docker compose -f docker-compose.dev.yml up -d
# письма (сброс пароля) ловятся на http://localhost:8025, реально никуда не
# уходят. Для прод-провайдера переопределите все SMTP_*, обычно нужны
# SMTP_USER/SMTP_PASSWORD и SMTP_USE_TLS=true (например, Yandex: smtp.yandex.ru:465).
#SMTP_HOST=localhost
#SMTP_PORT=1025
#SMTP_USER=
#SMTP_PASSWORD=
#SMTP_USE_TLS=false
#SMTP_FROM_EMAIL=no-reply@saitama-barbershop.local
#SMTP_FROM_NAME=Барбершоп «Сайтама»

# Базовый URL SPA — используется для ссылки сброса пароля в письме
#FRONTEND_BASE_URL=http://localhost:5173

# VK ID (OAuth 2.1 + PKCE) — получить client_id/secret на id.vk.com/business,
# redirect URI приложения должен совпадать с VK_REDIRECT_URI (VK ID разрешает
# http://localhost:8000/... на этапе разработки). Без VK_CLIENT_ID кнопка
# "Войти через VK" остаётся неактивной — см. GET /api/auth/vk/enabled.
#VK_CLIENT_ID=
#VK_CLIENT_SECRET=
#VK_REDIRECT_URI=http://localhost:8000/api/auth/vk/callback
